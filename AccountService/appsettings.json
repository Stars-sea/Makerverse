{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakOptions": {
    "Realm": "makerverse",
    "PublicClientId": "makerverse",
    "InternalBaseUrl": "http://localhost:6001"
  },
  "KeycloakAdminOptions": {
    "ClientId": "makerverse-account-service",
    "ClientSecret": ""
  },
  "AvatarOptions": {
    "BucketName": "avatars",
    "MaxFileSizeBytes": 5242880,
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/webp"],
    "CacheMaxAgeSeconds": 3600
  }
}
